# Normalise line endings: LF in the repository for all text files.
* text=auto eol=lf

# Explicitly treat these as text.
*.py    text eol=lf
*.pyi   text eol=lf
*.md    text eol=lf
*.yaml  text eol=lf
*.yml   text eol=lf
*.toml  text eol=lf
*.ini   text eol=lf
*.mako  text eol=lf
Dockerfile text eol=lf
Makefile   text eol=lf

# Binary files (never touch).
*.png binary
*.jpg binary
*.db  binary
