# ───────────────────────── Telegram ─────────────────────────
# Token from @BotFather (required).
BOT_TOKEN=123456:PUT-YOUR-TOKEN-HERE

# ───────────────────────── Database ─────────────────────────
# Default: local SQLite file (zero setup).
DATABASE_URL=sqlite+aiosqlite:///./ogebot.db
# PostgreSQL example (used by docker-compose):
# DATABASE_URL=postgresql+asyncpg://ogebot:ogebot@db:5432/ogebot

# Create tables automatically on startup (fine for SQLite / quick start).
# Set to false in production and use Alembic migrations instead.
INIT_DB_ON_STARTUP=true
SQL_ECHO=false

# ───────────────────────── FSM storage ──────────────────────
# Leave empty to keep user progress in memory (lost on restart).
# Set to persist FSM state across restarts:
# REDIS_URL=redis://redis:6379/0
REDIS_URL=

# ───────────────────────── Access / behaviour ───────────────
# Comma-separated Telegram user IDs allowed to run /reload and /stats.
ADMIN_IDS=

# Show correct/incorrect immediately after each answer (true), or reveal the
# score only at the end like a real exam (false).
IMMEDIATE_FEEDBACK=true

# Directory with YAML task banks.
DATA_DIR=data

# ───────────────────────── Logging ──────────────────────────
LOG_LEVEL=INFO
LOG_JSON=false
